# ──────────────────────────────────────────────────────────────────────────────
# Smart Campus Mobility — environment template
# Copy to server/.env for local development (docker compose sets its own env).
# ──────────────────────────────────────────────────────────────────────────────

# ---- Server (Express API) ----------------------------------------------------
NODE_ENV=development
PORT=4000

# Postgres — matches `docker compose up postgres`
DATABASE_URL=postgresql://scm:scm@localhost:5432/scm

# Redis — driver geo-index, Socket.IO adapter, BullMQ queues
REDIS_URL=redis://localhost:6379

# JWT signing secrets (min 16 chars). Generate real ones:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-too
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Comma-separated origins allowed to call the API with credentials
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Dispatch tuning
RIDE_DISPATCH_TIMEOUT_SEC=180     # REQUESTED → EXPIRED if nobody accepts
SCHEDULED_DISPATCH_LEAD_MIN=10    # promote scheduled rides this many minutes early

# ---- Optional: S3-compatible document storage ---------------------------------
# Leave unset to store driver documents on local disk under ./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# ---- Web (Next.js) — put these in web/.env.local ------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
